{
  "name": "soundcloud-migrate-cli",
  "version": "0.1.0",
  "description": "CLI tool to migrate actions between SoundCloud accounts using the official API",
  "type": "module",
  "bin": {
    "sc-migrate": "dist/cli.js"
  },
  "scripts": {
